# Copy this file to .env.local and fill in your values.
# Never commit .env.local — it contains secrets.

# ── Supabase ──────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# ── TMDB (movie search) ───────────────────────────────────
# Get your key at https://www.themoviedb.org/settings/api
NEXT_PUBLIC_TMDB_API_KEY=YOUR_TMDB_KEY

# ── Mailchimp (welcome email) ─────────────────────────────
# API key: Mailchimp → Account → Extras → API Keys
# The key ends with a datacenter suffix, e.g. abc123-us1
MAILCHIMP_API_KEY=YOUR_API_KEY-us1

# Audience ID: Mailchimp → Audience → Settings →
#   "Audience name and defaults" → scroll to Audience ID
MAILCHIMP_AUDIENCE_ID=YOUR_AUDIENCE_ID
